# Database
DATABASE_URL=postgres://pipeline:pipeline@localhost:5432/pipeline?sslmode=disable

# API
HTTP_ADDR=:8080

# Worker tuning
CLASSIFY_BATCH_SIZE=10
POLL_INTERVAL=500ms
RETRY_BACKOFF=2s

# Classifier selection
CLASSIFIER=mock                 # mock | claude
CLASSIFY_DEMO_DELAY=50ms        # per-token mock delay so progress is visible (demo only)

# Real classifier (CLASSIFIER=claude) — fill in tomorrow
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
